<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/generator_header"
        android:background="?attr/colorAccent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textAppearance="?android:attr/textAppearanceMedium"
            android:textStyle="bold"
            android:textColor="#ff000000"
            android:padding="15dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Payload Generator"
            android:layout_weight="1"/>
        <View
            android:id="@+id/close_generator_dialog"
            android:background="@drawable/ic_close_dialog"
            android:layout_width="40dp"
            android:layout_height="40dp"/>
    </LinearLayout>
    <ScrollView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/generator_header">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:orientation="vertical"
                android:padding="15dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textColor="?attr/colorAccent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="URL/Host"/>
                <EditText
                    android:id="@+id/url_host"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:hint="m.google.com"
                    android:ems="10"
                    android:inputType="textUri"/>
                <TextView
                    android:textColor="?attr/colorAccent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Split Mode"/>
                <RadioGroup
                    android:orientation="horizontal"
                    android:id="@+id/split_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:weightSum="3">
                    <RadioButton
                        android:id="@+id/split_instant"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Instant"
                        android:layout_weight="1"/>
                    <RadioButton
                        android:id="@+id/split_delay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Delay"
                        android:layout_weight="1"/>
                    <RadioButton
                        android:id="@+id/split_none"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Normal"
                        android:layout_weight="1"/>
                </RadioGroup>
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:weightSum="2">
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">
                        <TextView
                            android:textColor="?attr/colorAccent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Request Method"/>
                        <Spinner
                            android:id="@+id/request_method"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_alignParentRight="true">
                        <TextView
                            android:textColor="?attr/colorAccent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Injection Method"/>
                        <Spinner
                            android:id="@+id/inject_method"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"/>
                    </LinearLayout>
                </LinearLayout>
                <TextView
                    android:textColor="?attr/colorAccent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Query Mode"/>
                <RadioGroup
                    android:orientation="horizontal"
                    android:id="@+id/query_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp">
                    <RadioButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Normal"
                        android:layout_weight="1"/>
                    <RadioButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Front Query"
                        android:layout_weight="1"/>
                    <RadioButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Back Query"
                        android:layout_weight="1"/>
                </RadioGroup>
                <TextView
                    android:textColor="?attr/colorAccent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Extra Headers"/>
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:weightSum="2">
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">
                        <CheckBox
                            android:id="@+id/online_host"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Online-Host"/>
                        <CheckBox
                            android:id="@+id/reverse_proxy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Reverse-Proxy"/>
                        <CheckBox
                            android:id="@+id/paygen_proxy_auth"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Proxy-Authorization"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">
                        <CheckBox
                            android:id="@+id/forward_host"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Forward-Host"/>
                        <CheckBox
                            android:id="@+id/keep_alive"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Keep-Alive"/>
                        <CheckBox
                            android:id="@+id/dual_connect"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dual-Connect"/>
                    </LinearLayout>
                </LinearLayout>
                <Button
                    android:textColor="#ff000000"
                    android:id="@+id/generate_payload"
                    android:background="?attr/colorAccent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="GENERATE"/>
            </LinearLayout>
        </RelativeLayout>
    </ScrollView>
</RelativeLayout>
