<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="horizontal"
    android:id="@+id/network_selection_frame"
    android:background="@null"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:layout_gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="4dp">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_gravity="left"
                android:id="@+id/network_item_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="40dp"
                android:text="Network"/>
            <TextView
                android:textSize="10sp"
                android:textColor="@color/primary_color"
                android:layout_gravity="left"
                android:id="@+id/network_item_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="40dp"
                android:text="Network Info"/>
        </LinearLayout>
    </RelativeLayout>
    <ImageView
        android:layout_gravity="center"
        android:id="@+id/network_export_icon"
        android:visibility="visible"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginRight="37dp"
        android:src="0x7f0800be"
        android:tint="@color/primary_color"/>
    <ImageView
        android:layout_gravity="center"
        android:id="@+id/network_delete_icon"
        android:visibility="visible"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginRight="13dp"
        android:src="@drawable/ic_delete"
        android:tint="@color/primary_color"/>
    <ImageView
        android:layout_gravity="center"
        android:id="@+id/network_item_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginLeft="10dp"/>
</FrameLayout>
