<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:layout_gravity="center"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_margin="25dp"
            android:src="@drawable/ic_app_icon"/>
        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:orientation="vertical"
                        android:background="@drawable/user_icon_bg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:layout_margin="10dp"
                            android:src="@drawable/ic_user"
                            android:tint="#ffffff"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:background="@drawable/user_pass_holder_bg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <EditText
                            android:id="@+id/login_username"
                            android:background="#00000000"
                            android:paddingLeft="10dp"
                            android:layout_width="match_parent"
                            android:layout_height="45dp"
                            android:hint="Username"
                            android:ems="10"
                            android:inputType="textEmailAddress"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:orientation="vertical"
                        android:background="@drawable/user_icon_bg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:layout_margin="10dp"
                            android:src="0x7f08012a"
                            android:tint="#ffffff"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:background="@drawable/user_pass_holder_bg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <rased.vpn.app.view.MaterialEditText
                            android:id="@+id/login_password"
                            android:background="#00000000"
                            android:paddingLeft="10dp"
                            android:paddingRight="10dp"
                            android:layout_width="match_parent"
                            android:layout_height="45dp"
                            android:hint="Password"
                            android:ems="10"
                            android:inputType="textPassword"
                            app:tint_color="@color/primary_color"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
            <Button
                android:typeface="serif"
                android:textColor="#ffffffff"
                android:id="@+id/login_button"
                android:background="@drawable/button_connect"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Login"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
