<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#3e001d"
                android:endColor="@color/primaryDark_color"
                android:angle="360"/>
            <corners android:radius="25dp"/>
        </shape>
    </item>
    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/accent_color"/>
            <corners android:radius="25dp"/>
        </shape>
    </item>
</layer-list>
